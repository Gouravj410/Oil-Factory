# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Security Keys
SECRET_KEY=fmcg-dev-secret-key-2024-change-in-production
JWT_SECRET_KEY=fmcg-jwt-secret-key-2024-change-in-production

# Database Configuration
# PostgreSQL - update with your actual credentials
DATABASE_URL=postgresql://fmcg_user:fmcg_password@localhost:5432/fmcg_rewards

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Redis Configuration (optional - falls back to in-memory if not available)
REDIS_URL=redis://localhost:6379

# Base URL
BASE_URL=http://localhost:5000

# File Upload
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=104857600

# Logging
LOG_LEVEL=DEBUG
LOG_FILE=app.log

# Batch Processing
BATCH_SIZE=1000
EXPORT_BATCH_SIZE=5000
